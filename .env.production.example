# ─── Required: Supabase ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Required: App ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=GuestCompass
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ─── Required: Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_NAME=gc_jobs
BULLMQ_CONCURRENCY=20

# ─── WhatsApp Cloud API (Meta) ─────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
WHATSAPP_ACCESS_TOKEN=<your-access-token>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<your-webhook-verify-token>
WHATSAPP_APP_SECRET=<your-app-secret>
WHATSAPP_BUSINESS_ACCOUNT_ID=<your-waba-id>
WHATSAPP_API_VERSION=v21.0

# ─── Worker ────────────────────────────────────────────────
WORKER_HTTP=1
WORKER_HTTP_PORT=9090

# ─── Optional: Monitoring ──────────────────────────────────
# SENTRY_DSN=https://key@sentry.io/project-id
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ─── Optional: Email ────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# ─── Optional: Feature Flags ────────────────────────────────
# FEATURE_DEMO_MODE=false
# FEATURE_WEBHOOKS_ENABLED=true
# FEATURE_RATE_LIMITING_ENABLED=true

# ─── Optional: Security ─────────────────────────────────────
# SESSION_SECRET=your-secure-random-secret
# ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ─── Optional: Analytics ────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXX
# NEXT_PUBLIC_MIXPANEL_TOKEN=your-token
