# ─── Required: Supabase ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Required: App ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GuestCompass

# ─── Required: Redis (for queue processing) ─────────────────
# REDIS_URL=redis://localhost:6379

# ─── WhatsApp Cloud API (Meta) ─────────────────────────────
# Get from https://developers.facebook.com/apps -> WhatsApp -> Getting Started
# WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
# WHATSAPP_ACCESS_TOKEN=<your-access-token>
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=<your-verify-token>
# WHATSAPP_APP_SECRET=<your-app-secret>
# WHATSAPP_BUSINESS_ACCOUNT_ID=<your-waba-id>
# WHATSAPP_API_VERSION=v21.0

# ─── Optional: Features ────────────────────────────────────
# FEATURE_DEMO_MODE=false
# BULLMQ_CONCURRENCY=20
# BULLMQ_QUEUE_NAME=gc_jobs

# ─── Optional: Monitoring ──────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ─── Optional: PMS Integration ─────────────────────────────
# PMS_PROVIDER=
# PMS_API_KEY=
# PMS_PROPERTY_ID=

# ─── Optional: Stripe / Billing ────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
